# ─── App ────────────────────────────────────────────────────
DATABASE_URL=postgresql://emailuser:emailpass@localhost:5432/ai_email_db
SECRET_KEY=change-this-to-a-long-random-secret-key-32chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Gmail OAuth2 ───────────────────────────────────────────
GMAIL_CLIENT_ID=your-gmail-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REDIRECT_URI=http://localhost:8000/api/integrations/gmail/callback

# ─── Outlook (Microsoft) OAuth2 ─────────────────────────────
OUTLOOK_CLIENT_ID=your-outlook-client-id
OUTLOOK_CLIENT_SECRET=your-outlook-client-secret
OUTLOOK_TENANT_ID=common
OUTLOOK_REDIRECT_URI=http://localhost:8000/api/integrations/outlook/callback

# ─── IMAP Fallback (direct email access) ────────────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# ─── Notification Settings ──────────────────────────────────
NOTIFY_ON_NEGATIVE=true
NOTIFY_ON_CRITICAL=true
FETCH_INTERVAL_SECONDS=300
